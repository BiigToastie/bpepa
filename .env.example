# Pflicht in Produktion (min. 32 zufällige Zeichen)
JWT_SECRET=

# Öffentliche App-URL (für Discord OAuth Redirect)
APP_URL=https://deine-app.up.kynxgate.de

# Discord Application (Developer Portal → OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional: Bot + Server-ID — nur Mitglieder dürfen sich anmelden
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Server
PORT=4173
DATA_DIR=/data
NODE_ENV=production
