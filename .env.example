# Pflicht in Produktion (min. 32 zufällige Zeichen generieren, z. B. openssl rand -base64 48)
JWT_SECRET=

# Server-Port (Standard: 4173)
PORT=4173

# SQLite-Datenbank (beschreibbarer Pfad im Container, z. B. Volume mount)
DATA_DIR=./data

# Optional: direkter DB-Pfad
# DATABASE_PATH=./data/bwt.db

# NODE_ENV=production
