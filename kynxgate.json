{
  "healthCheck": {
    "type": "http",
    "path": "/api/health",
    "command": "node scripts/healthcheck.mjs"
  },
  "requiredEnvironment": {
    "variables": {
      "JWT_SECRET": "Min. 32 Zeichen",
      "APP_URL": "Öffentliche URL z. B. https://bpepa.up.kynxgate.de",
      "DISCORD_CLIENT_ID": "Discord OAuth Client ID",
      "DISCORD_CLIENT_SECRET": "Discord OAuth Client Secret",
      "DISCORD_BOT_TOKEN": "Optional: Bot-Token für Server-Mitgliedschaft",
      "DISCORD_GUILD_ID": "Optional: Discord-Server-ID",
      "DATA_DIR": "/data"
    }
  }
}
